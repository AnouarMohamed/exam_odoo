<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_travel_agency" model="ir.module.category">
        <field name="name">Agence de Voyages</field>
        <field name="description">Gestion des réservations, départs et packages touristiques.</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_travel_user" model="res.groups">
        <field name="name">Utilisateur Agence de Voyages</field>
        <field name="category_id" ref="module_category_travel_agency"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_travel_manager" model="res.groups">
        <field name="name">Responsable Agence de Voyages</field>
        <field name="category_id" ref="module_category_travel_agency"/>
        <field name="implied_ids" eval="[(4, ref('group_travel_user')), (4, ref('sales_team.group_sale_manager'))]"/>
    </record>

    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_travel_manager'))]"/>
    </record>
</odoo>
