<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_travel_booking_user_own" model="ir.rule">
        <field name="name">Réservations personnelles des agents</field>
        <field name="model_id" ref="model_travel_booking"/>
        <field name="domain_force">['|', ('responsible_user_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('travel_agency_management.group_travel_user'))]"/>
    </record>

    <record id="rule_travel_booking_manager_all" model="ir.rule">
        <field name="name">Toutes les réservations pour les responsables</field>
        <field name="model_id" ref="model_travel_booking"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('travel_agency_management.group_travel_manager'))]"/>
    </record>

    <record id="rule_travel_passenger_user_own_booking" model="ir.rule">
        <field name="name">Voyageurs liés aux réservations personnelles</field>
        <field name="model_id" ref="model_travel_passenger"/>
        <field name="domain_force">['|', ('booking_id.responsible_user_id', '=', user.id), ('booking_id.create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('travel_agency_management.group_travel_user'))]"/>
    </record>

    <record id="rule_travel_passenger_manager_all" model="ir.rule">
        <field name="name">Tous les voyageurs pour les responsables</field>
        <field name="model_id" ref="model_travel_passenger"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('travel_agency_management.group_travel_manager'))]"/>
    </record>
</odoo>
