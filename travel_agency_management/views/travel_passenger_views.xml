<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_travel_passenger_tree" model="ir.ui.view">
        <field name="name">travel.passenger.tree</field>
        <field name="model">travel.passenger</field>
        <field name="arch" type="xml">
            <tree string="Voyageurs">
                <field name="name"/>
                <field name="booking_id"/>
                <field name="date_of_birth"/>
                <field name="age"/>
                <field name="nationality_id"/>
                <field name="passport_number"/>
                <field name="phone"/>
                <field name="email"/>
            </tree>
        </field>
    </record>

    <record id="view_travel_passenger_form" model="ir.ui.view">
        <field name="name">travel.passenger.form</field>
        <field name="model">travel.passenger</field>
        <field name="arch" type="xml">
            <form string="Voyageur">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="booking_id"/>
                            <field name="date_of_birth"/>
                            <field name="age" readonly="1"/>
                        </group>
                        <group>
                            <field name="nationality_id"/>
                            <field name="passport_number"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_travel_passenger_search" model="ir.ui.view">
        <field name="name">travel.passenger.search</field>
        <field name="model">travel.passenger</field>
        <field name="arch" type="xml">
            <search string="Rechercher un voyageur">
                <field name="name"/>
                <field name="booking_id"/>
                <field name="nationality_id"/>
                <field name="passport_number"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Réservation" name="group_booking" context="{'group_by': 'booking_id'}"/>
                    <filter string="Nationalité" name="group_nationality" context="{'group_by': 'nationality_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_travel_passenger" model="ir.actions.act_window">
        <field name="name">Voyageurs</field>
        <field name="res_model">travel.passenger</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_travel_passenger_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Consultez les voyageurs liés aux réservations.</p>
        </field>
    </record>
</odoo>
