      <bpmndi:BPMNShape id="Task_Soumet_Reservation_di" bpmnElement="Task_Soumet_Reservation">
        <dc:Bounds x="1440" y="302" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Verifie_Disponibilite_di" bpmnElement="Task_Verifie_Disponibilite">
        <dc:Bounds x="1650" y="477" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Controle_Capacite_di" bpmnElement="Task_Controle_Capacite">
        <dc:Bounds x="1860" y="640" width="150" height="80"/>
      </bpmndi:BPMNShape>
