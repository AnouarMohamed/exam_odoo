      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Autre_Depart_di" bpmnElement="Task_Autre_Depart">
        <dc:Bounds x="2070" y="302" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Approuve_di" bpmnElement="Task_Approuve">
        <dc:Bounds x="2260" y="477" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cree_Devis_di" bpmnElement="Task_Cree_Devis">
        <dc:Bounds x="2470" y="640" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Confirme_Devis_di" bpmnElement="Task_Confirme_Devis">
