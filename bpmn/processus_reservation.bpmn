      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01"><di:waypoint x="226" y="168"/><di:waypoint x="270" y="168"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02"><di:waypoint x="420" y="168"/><di:waypoint x="480" y="342"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03"><di:waypoint x="630" y="342"/><di:waypoint x="690" y="342"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04"><di:waypoint x="840" y="342"/><di:waypoint x="925" y="193"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05"><di:waypoint x="950" y="168"/><di:waypoint x="1020" y="168"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06"><di:waypoint x="925" y="193"/><di:waypoint x="1020" y="342"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07"><di:waypoint x="1170" y="342"/><di:waypoint x="1230" y="680"/></bpmndi:BPMNEdge>
